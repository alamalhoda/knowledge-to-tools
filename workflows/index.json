{
  "backend-api-flow": {
    "id": "backend-api-flow",
    "name": "Backend REST API Implementation",
    "description": "Standard workflow for implementing backend REST APIs with Django and DRF.",
    "domain": "backend",
    "category": "api",
    "triggers": ["rest\\s?api", "endpoint", "crud", "django", "api"],
    "agents": ["architect", "backend", "reviewer"],
    "capabilities_required": ["backend-development", "code-review"],
    "priority": 80,
    "stages": [
      {
        "id": "architecture",
        "name": "Architecture Design",
        "agent": "architect",
        "depends_on": [],
        "required_knowledge": ["backend-architecture-django-architecture", "backend-api-rest"],
        "required_capabilities": ["system-design"],
        "status": "pending"
      },
      {
        "id": "implementation",
        "name": "Implementation",
        "agent": "backend",
        "depends_on": ["architecture"],
        "required_knowledge": ["backend-api-rest", "backend-database-models", "backend-performance-optimization"],
        "required_capabilities": ["django-development", "api-design"],
        "status": "pending"
      },
      {
        "id": "review",
        "name": "Code Review",
        "agent": "reviewer",
        "depends_on": ["implementation"],
        "required_knowledge": ["backend-security-security", "backend-patterns-anti-patterns"],
        "required_capabilities": ["code-review", "security-audit"],
        "status": "pending"
      }
    ]
  },
