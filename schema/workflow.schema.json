{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Aegis WorkflowIR v2 (DAG)",
  "type": "object",
  "required": ["id", "name", "domain", "stages"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "domain": { "type": "string" },
    "description": { "type": "string" },
    "agents": { "type": "array", "items": { "type": "string" } },
    "triggers": { "type": "array", "items": { "type": "string" } },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "agent"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "agent": { "type": "string" },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "required_knowledge": { "type": "array", "items": { "type": "string" } },
          "output_to": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}